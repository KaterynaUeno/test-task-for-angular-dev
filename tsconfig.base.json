{
  "compileOnSave": false,
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "es2020",
    "lib": ["es2018", "dom"],
    "baseUrl": "./",
    "paths": {
      "@app/*": ["apps/test-task-for-angular-dev/src/app/*"],
      "@core": ["apps/test-task-for-angular-dev/src/app/@core"],
      "@core/*": ["apps/test-task-for-angular-dev/src/app/@core/*"],
      "@shared": ["apps/test-task-for-angular-dev/src/app/@shared"],
      "@shared/*": ["apps/test-task-for-angular-dev/src/app/@shared/*"],
      "@env/*": ["apps/test-task-for-angular-dev/src/environments/*"],
      "@weather/state": ["libs/weather/state/index.ts"],
      "@weather/ui": ["libs/weather/ui/index.ts"]
    }
  }
}
