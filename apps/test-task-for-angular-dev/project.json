{
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "name": "ng-x-rocket",
  "projectType": "application",
  "generators": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "sourceRoot": "apps/test-task-for-angular-dev/src",
  "prefix": "app",
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "options": {
        "outputPath": {
          "base": "dist"
        },
        "index": "apps/test-task-for-angular-dev/src/index.html",
        "polyfills": ["apps/test-task-for-angular-dev/src/polyfills.ts"],
        "tsConfig": "tsconfig.app.json",
        "assets": [
          "apps/test-task-for-angular-dev/src/favicon.ico",
          "apps/test-task-for-angular-dev/src/apple-touch-icon.png",
          "apps/test-task-for-angular-dev/src/robots.txt",
          "apps/test-task-for-angular-dev/src/manifest.webmanifest",
          "apps/test-task-for-angular-dev/src/assets"
        ],
        "styles": ["apps/test-task-for-angular-dev/src/main.scss"],
        "scripts": [],
        "extractLicenses": false,
        "sourceMap": true,
        "optimization": false,
        "namedChunks": true,
        "browser": "apps/test-task-for-angular-dev/src/main.ts",
        "stylePreprocessorOptions": {
          "includePaths": ["node_modules", "apps/test-task-for-angular-dev/src"]
        }
      },
      "configurations": {
        "production": {
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "10kb"
            }
          ],
          "serviceWorker": "true",
          "fileReplacements": [
            {
              "replace": "apps/test-task-for-angular-dev/src/environments/environment.ts",
              "with": "apps/test-task-for-angular-dev/src/environments/environment.prod.ts"
            }
          ]
        },
        "ci": {
          "progress": false
        }
      },
      "defaultConfiguration": "",
      "outputs": ["{options.outputPath.base}"]
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "buildTarget": "ng-x-rocket:build"
      },
      "configurations": {
        "production": {
          "buildTarget": "ng-x-rocket:build:production"
        },
        "ci": {}
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "ng-x-rocket:build"
      }
    },
    "test": {
      "executor": "@angular-builders/jest:run",
      "options": {
        "watch": true
      },
      "configurations": {
        "ci": {
          "watch": false,
          "ci": true,
          "coverage": true,
          "silent": true
        }
      }
    },
    "e2e": {
      "executor": "@angular-devkit/build-angular:protractor",
      "options": {
        "protractorConfig": "e2e/protractor.conf.js",
        "devServerTarget": "ng-x-rocket:serve"
      },
      "configurations": {
        "production": {
          "devServerTarget": "ng-x-rocket:serve:production"
        }
      }
    }
  }
}
